PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Better Auth
BETTER_AUTH_SECRET=replace-me-with-32-byte-secret
BETTER_AUTH_URL=http://localhost:8000
DATABASE_URL=
DIRECT_URL=
READONLY_DATABASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google OAuth redirect URI: http://localhost:8000/api/auth/callback/google

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
# Proof uploads use Cloudinary public URLs.

# AI SDK
# Gemini (Primary Chatbot)
GEMINI_API_KEY=
GEMINI_MODEL_LLM=gemini-3.1-flash-lite
# @ai-sdk/google reads this env var by default. Use same key as GEMINI_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=

# Team-Idea Fit Evaluation
AI_TEAM_FIT_MODEL=gemini-2.0-flash

# V98 (OpenAI-compatible Fallback)
V98_BASE_URL=https://v98store.com/v1
V98_API_KEY=
OPENAI_MODEL_LLM=gpt-5.4

# Logging (Pino + Grafana Loki)
LOG_LEVEL=info
SERVICE_NAME=nexus-api
ENABLE_LOKI=false
# Grafana Cloud Loki push endpoint
LOKI_URL=
# Loki basic auth: User (numeric ID)
LOKI_USER=
# Loki basic auth: API token or password
LOKI_PASSWORD=

# Bank transfer info (displayed on payment page + QR)
BANK_SHORT_CODE=BIDV
BANK_NAME="BIDV (Ngân hàng TMCP Đầu tư và Phát triển Việt Nam)"
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME="NEXUS PLATFORM"

# SePay payment gateway (auto-verify bank transfers via webhook)
# 1. Đăng ký tại https://my.sepay.vn
# 2. Vào Cấu hình chung → Cấu trúc mã thanh toán → Thêm mẫu:
#    Tiền tố: CR, Hậu tố 6-30, Loại: Số và chữ
# 3. WebHooks → Thêm webhook trỏ đến https://domain.com/api/payments/sepay-webhook
SEPAY_API_TOKEN=
SEPAY_WEBHOOK_API_KEY=

# Docker log rotation (set in docker run/compose, not in .env)
# --log-opt max-size=10m --log-opt max-file=3
# Keeps Docker host logs small since all JSON is already shipped to Loki.
