{
  "name": "nexus-platform-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "build": "npm run prisma:generate && tsc",
    "check-types": "npm run prisma:generate && tsc --noEmit",
    "start": "node dist/index.js",
    "test": "tsx --test src/shared/infrastructure/tests/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage src/shared/infrastructure/tests/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.74",
    "@hono/node-server": "^2.0.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^5.0.44",
    "better-auth": "^1.4.3",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.2.3",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
